{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "tracebloc",
  "colors": {
    "primary": "#0184A3",
    "light": "#ffffff",
    "dark": "#000000"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "family": "Barlow",
    "heading": {
      "family": "Barlow",
      "weight": 500
    },
    "body": {
      "family": "Barlow"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://tracebloc.io"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://tracebloc.io/blog"
        },
        {
          "anchor": "Platform",
          "icon": "rocket",
          "href": "https://ai.tracebloc.io"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview/tracebloc"
            ]
          },
          {
            "group": "Create a Use Case",
            "expanded": true,
            "pages": [
              "create-use-case/prerequisites",
              "create-use-case/prepare-dataset",
              "create-use-case/define",
              "create-use-case/evaluate-models",
              "create-use-case/templates"
            ]
          },
          {
            "group": "Join a Use Case",
            "pages": [
              "join-use-case/overview",
              "join-use-case/explore-use-case",
              "join-use-case/join-use-case",
              "join-use-case/start-training",
              "join-use-case/hyperparameters",
              "join-use-case/model-optimization",
              "join-use-case/model-evaluation"
            ]
          },
          {
            "group": "Environment Setup",
            "pages": [
              "environment-setup/setup-guide",
              "environment-setup/configuration",
              "environment-setup/eks-client-deployment-guide",
              "environment-setup/troubleshooting"
            ]
          },
          {
            "group": "Tools & Help",
            "pages": [
              "tools-help/tracebloc-package",
              "tools-help/faqs",
              "tools-help/key-terms"
            ]
          }
        ]
      }
    ]
  },
  "logo": "/logo/light.svg",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@tracebloc.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://ai.tracebloc.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/tracebloc",
      "linkedin": "https://www.linkedin.com/company/tracebloc",
      "discord": "https://discord.gg/tracebloc"
    }
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-9CS3JNFFRJ"
    }
  },
  "redirects": [
    { "source": "/getting-started/overview", "destination": "/overview/tracebloc" },
    { "source": "/getting-started/quickstart", "destination": "/environment-setup/setup-guide" },
    { "source": "/getting-started/core-concepts", "destination": "/tools-help/key-terms" },
    { "source": "/getting-started/pricing", "destination": "https://tracebloc.io/#pricing" },
    { "source": "/environment-setup/deployment-guide", "destination": "/environment-setup/setup-guide" },
    { "source": "/environment-setup/local-deployment-guide-macos", "destination": "/environment-setup/setup-guide" },
    { "source": "/environment-setup/local-deployment-guide-linux", "destination": "/environment-setup/setup-guide" },
    { "source": "/environment-setup/azure-deployment-guide", "destination": "/environment-setup/eks-client-deployment-guide" },
    { "source": "/environment-setup/eks-deployment-guide", "destination": "/environment-setup/eks-client-deployment-guide" },
    { "source": "/environment-setup/architecture", "destination": "/environment-setup/configuration" },
    { "source": "/environment-setup/setup_eks.sh", "destination": "/environment-setup/eks-client-deployment-guide" },
    { "source": "/join-use-case/tracebloc-package", "destination": "/tools-help/tracebloc-package" },
    { "source": "/join-use-case/model-optimisation.md", "destination": "/join-use-case/model-optimization" },
    { "source": "/join-use-case/join-use-case/model-optimisation.md", "destination": "/join-use-case/model-optimization" },
    { "source": "/tracebloc-package/user-linkModelDataset", "destination": "/tools-help/tracebloc-package" },
    { "source": "/experiment/details", "destination": "/join-use-case/explore-use-case" },
    { "source": "/experiment/exp-guide", "destination": "/join-use-case/start-training" },
    { "source": "/collaboration/collaboration-overview", "destination": "/join-use-case/overview" },
    { "source": "/collaboration/dataset-guide", "destination": "/create-use-case/prepare-dataset" },
    { "source": "/collaboration/leaderboard", "destination": "/join-use-case/model-evaluation" },
    { "source": "/collaboration/prizes", "destination": "/join-use-case/overview" },
    { "source": "/create-use-case/set-evaluation", "destination": "/create-use-case/evaluate-models" },
    { "source": "/client-setup/setup-requirements", "destination": "/environment-setup/setup-guide" },
    { "source": "/training-guide/jupyter-notebook", "destination": "/join-use-case/start-training" },
    { "source": "/model-requirements/api-supported", "destination": "/tools-help/tracebloc-package" },
    { "source": "/model-requirements/model-zoo", "destination": "/create-use-case/templates" },
    { "source": "/FAQ/Collaboration", "destination": "/tools-help/faqs" },
    { "source": "/FAQ/General", "destination": "/tools-help/faqs" },
    { "source": "/key-terms/notifications", "destination": "/tools-help/key-terms" },
    { "source": "/key-terms/archive", "destination": "/tools-help/key-terms" },
    { "source": "/training-parameters/TrainingPlan", "destination": "/join-use-case/hyperparameters" },
    { "source": "/training-parameters/TrainingPlan-hyperparameter", "destination": "/join-use-case/hyperparameters" },
    { "source": "/training-parameters/TrainingPlan-datasetparameter", "destination": "/create-use-case/prepare-dataset" },
    { "source": "/training-parameters/TrainingPlan-llmparameter", "destination": "/join-use-case/hyperparameters" },
    { "source": "/training-parameters/TrainingPlan-trainingdescription", "destination": "/join-use-case/start-training" },
    { "source": "/training-parameters/TrainingPlan-notsupported", "destination": "/tools-help/faqs" },
    { "source": "/markdown-page", "destination": "/overview/tracebloc" },
    { "source": "/tags/:slug*", "destination": "/overview/tracebloc" },
    { "source": "/blog/authors", "destination": "https://tracebloc.io/blog" },
    { "source": "/blog/archive", "destination": "https://tracebloc.io/blog" },
    { "source": "/tracebloc-package", "destination": "/tools-help/tracebloc-package" }
  ],
  "seo": {
    "indexHiddenPages": false
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "search": {
    "prompt": "Search tracebloc docs..."
  }
}
