{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "tracebloc",
  "colors": {
    "primary": "#0184A3",
    "light": "#ffffff",
    "dark": "#000000"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "family": "Barlow",
    "heading": {
      "family": "Barlow"
    },
    "body": {
      "family": "Barlow"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://tracebloc.io"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://tracebloc.io/blog"
        },
        {
          "anchor": "Platform",
          "icon": "rocket",
          "href": "https://ai.tracebloc.io"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview/tracebloc"
            ]
          },
          {
            "group": "Create a Use Case",
            "expanded": true,
            "pages": [
              "create-use-case/prerequisites",
              "create-use-case/prepare-dataset",
              "create-use-case/define",
              "create-use-case/evaluate-models",
              "create-use-case/templates"
            ]
          },
          {
            "group": "Join a Use Case",
            "pages": [
              "join-use-case/explore-use-case",
              "join-use-case/join-use-case",
              "join-use-case/start-training",
              "join-use-case/hyperparameters",
              "join-use-case/model-optimization",
              "join-use-case/model-evaluation"
            ]
          },
          {
            "group": "Environment Setup",
            "pages": [
              "environment-setup/setup-guide",
              "environment-setup/configuration",
              "environment-setup/eks-client-deployment-guide",
              "environment-setup/troubleshooting"
            ]
          },
          {
            "group": "Tools & Help",
            "pages": [
              "tools-help/tracebloc-package",
              "tools-help/faqs",
              "tools-help/key-terms"
            ]
          }
        ]
      }
    ]
  },
  "logo": "/logo/light.svg",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@tracebloc.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://ai.tracebloc.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/tracebloc",
      "linkedin": "https://www.linkedin.com/company/tracebloc",
      "discord": "https://discord.gg/tracebloc"
    }
  },
  "seo": {
    "indexHiddenPages": false
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "search": {
    "prompt": "Search tracebloc docs..."
  }
}
